# Copier vers `.env` en local (non versionné). Sur Vercel : Environment Variables.

# --- Firebase (optionnel : voir src/lib/firebase.js) ---
# Valeurs = Paramètres du projet → Vos applications → appli Web (SDK).
# Sans ces clés, l’app reste en mode localStorage uniquement.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# measurementId de la console → plutôt VITE_GA_MEASUREMENT_ID ci‑dessous (GA4), pas obligatoire pour Auth/Firestore.

# --- Mesure d’usage ---
# Sur Vercel : projet → Analytics → activer « Web Analytics ».
# En production uniquement : @vercel/analytics envoie des vues agrégées (pas le profil ni les listes).
# Pour désactiver complètement le script (même en prod) :
# VITE_DISABLE_ANALYTICS=true
#
# Umami Cloud (https://cloud.umami.is) — vues + mêmes événements personnalisés que l’app.
# Website ID = réglages du site dans Umami (data-website-id).
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Désactiver uniquement Umami (Vercel inchangé) :
# VITE_DISABLE_UMAMI=true
# Tester Umami en local (charge le script même en dev) :
# VITE_UMAMI_DEV=true
#
# Google Analytics 4 — ID de mesure (Admin → Flux de données → G-…)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Désactiver uniquement GA4 :
# VITE_DISABLE_GA=true
# Activer GA4 en local (sinon : prod uniquement) :
# VITE_GA_DEV=true
