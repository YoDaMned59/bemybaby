# Copier vers `.env` en local (non versionné). Sur Vercel : Environment Variables.

# Lien vers un formulaire de retour bêta (Google Forms, Tally, Typeform…)
# Si défini au build, il remplace l’URL par défaut dans src/config/site.js (Vercel : bien l’ajouter).
# VITE_FEEDBACK_URL=https://forms.gle/WpRd2d5diUUAVuqp8

# Sinon : adresse pour ouvrir le client mail avec sujet prérempli
# VITE_FEEDBACK_EMAIL=toi@exemple.com

# --- Mesure d’usage ---
# Sur Vercel : projet → Analytics → activer « Web Analytics ».
# En production uniquement : @vercel/analytics envoie des vues agrégées (pas le profil ni les listes).
# Pour désactiver complètement le script (même en prod) :
# VITE_DISABLE_ANALYTICS=true
#
# Umami Cloud (https://cloud.umami.is) — vues + mêmes événements personnalisés que l’app.
# Website ID = réglages du site dans Umami (data-website-id).
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Désactiver uniquement Umami (Vercel inchangé) :
# VITE_DISABLE_UMAMI=true
# Tester Umami en local (charge le script même en dev) :
# VITE_UMAMI_DEV=true
#
# PostHog Cloud (région EU) — clé projet (Paramètres du projet → API) phc_…
# Hôte par défaut : https://eu.i.posthog.com
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Surcharge optionnelle de l’hôte (peu usuel) :
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Désactiver PostHog tout en gardant les autres outils :
# VITE_DISABLE_POSTHOG=true
# Envoyer des événements PostHog en local (hors production) :
# VITE_POSTHOG_DEV=true
